<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Banner Ad (320×50)"
        android:textAppearance="@style/TextAppearance.Material3.HeadlineSmall"
        android:paddingBottom="8dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
        android:text="OpenRTB bid request → HTML creative rendered in a MRAID 3.0 WebView container. MRC viewability threshold: 50% pixels visible for ≥1s."
        android:paddingBottom="16dp" />

    <ProgressBar
        android:id="@+id/progress_bar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:visibility="gone" />

    <TextView
        android:id="@+id/tv_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Tap Load to fetch a banner ad"
        android:textAppearance="@style/TextAppearance.Material3.BodySmall"
        android:paddingBottom="16dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_load_banner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Load Banner Ad"
        android:layout_marginBottom="16dp" />

    <!-- Publisher ad placement — add to your layout exactly like this -->
    <com.apexads.sdk.banner.BannerAdView
        android:id="@+id/banner_ad_view"
        android:layout_width="320dp"
        android:layout_height="50dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="8dp"
        android:background="#F5F5F5" />

</LinearLayout>
